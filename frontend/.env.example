# ----- Browser (Vite) -----
# Filled automatically by `pnpm deploy` in /contracts. Or set manually.
VITE_PAYROLL_POOL_ADDRESS=0x...
VITE_USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
VITE_CHAIN_ID=421614

# Get one free at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# ----- Serverless (Vercel cron at /api/advance-period) -----
# Set these in Vercel project settings -> Environment Variables (NOT prefixed with VITE_).
# KEEPER_PRIVATE_KEY: a dedicated wallet whose ONLY permission is calling advancePeriod().
#   Authorize this address via setKeeper(address, true) on the deployed contract.
# CRON_SECRET: long random string. Vercel sends it as Authorization: Bearer <CRON_SECRET>
#   on cron-triggered requests. Reject anything else.
# ARBITRUM_SEPOLIA_RPC_URL: same as the contracts deploy. Use a reliable RPC.
# PAYROLL_POOL_ADDRESS: the deployed PayrollPool contract.
KEEPER_PRIVATE_KEY=
CRON_SECRET=
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
PAYROLL_POOL_ADDRESS=
